meta {
  name: 成功取得空的客戶列表
  type: http
  seq: 2
}

vars {
  base_url: {{BASE_URL}}
}

GET {{base_url}}/api/customers
Content-Type: application/json

tests {
  test("HTTP 狀態碼應為 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("回應應該是空陣列", function() {
    expect(res.body).to.be.an('array');
    expect(res.body.length).to.equal(0);
  });
}
