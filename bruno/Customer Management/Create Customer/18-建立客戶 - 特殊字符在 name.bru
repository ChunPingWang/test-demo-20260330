meta {
  name: 建立客戶 - 特殊字符在 name
  type: http
  seq: 18
}

vars {
  base_url: {{BASE_URL}}
}

POST {{base_url}}/api/customers
Content-Type: application/json

{
  "name": "O'Brien-Smith",
  "email": "test@example.com"
}

tests {
  test("HTTP 狀態碼應為 201", function() {
    expect(res.status).to.equal(201);
  });
  
  test("回應的 name 應為 O'Brien-Smith", function() {
    expect(res.body.name).to.equal("O'Brien-Smith");
  });
}
