meta {
  name: 建立客戶失敗 - Email 已存在
  type: http
  seq: 10
}

vars {
  base_url: {{BASE_URL}}
}

POST {{base_url}}/api/customers
Content-Type: application/json

{
  "name": "Another User",
  "email": "existing@example.com"
}

tests {
  test("HTTP 狀態碼應為 400", function() {
    expect(res.status).to.equal(400);
  });
  
  test("錯誤訊息應包含 Email already exists", function() {
    const message = res.body.message || res.body.error || '';
    expect(message).to.include("Email already exists");
  });
}
