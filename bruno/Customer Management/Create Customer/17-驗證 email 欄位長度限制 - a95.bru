meta {
  name: 驗證 email 欄位長度限制 - a95
  type: http
  seq: 17
}

vars {
  base_url: {{BASE_URL}}
}

POST {{base_url}}/api/customers
Content-Type: application/json

{
  "name": "Test User",
  "email": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa@example.com"
}

tests {
  test("HTTP 狀態碼應為 400", function() {
    expect(res.status).to.equal(400);
  });
  
  test("錯誤訊息應為 Email must not exceed 100 characters", function() {
    const message = res.body.message || res.body.error || '';
    expect(message).to.equal("Email must not exceed 100 characters");
  });
}
