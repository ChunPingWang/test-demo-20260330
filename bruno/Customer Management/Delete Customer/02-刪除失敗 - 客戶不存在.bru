meta {
  name: 刪除失敗 - 客戶不存在
  type: http
  seq: 2
}

vars {
  base_url: {{BASE_URL}}
}

DELETE {{base_url}}/api/customers/9999
Content-Type: application/json

tests {
  test("HTTP 狀態碼應為 404", function() {
    expect(res.status).to.equal(404);
  });
  
  test("錯誤訊息應包含 Customer not found", function() {
    const message = res.body.message || res.body.error || '';
    expect(message).to.include("Customer not found");
  });
}
